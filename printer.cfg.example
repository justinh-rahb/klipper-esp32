# Panda Breath — Klipper configuration (Pathway 3: KlipperMCU firmware)
#
# Prerequisites:
#   1. Flash klipper-firmware/ to the Panda Breath over USB-C:
#        cd klipper-firmware
#        idf.py set-target esp32c3
#        idf.py build
#        idf.py -p /dev/cu.wchusbserial* flash
#   2. Copy the generated klipper.dict to the Klipper host:
#        scp components/klipper/klipper/out/klipper.dict lava@<u1-ip>:~/
#   3. Connect Panda Breath USB-C to a USB-A port on the Snapmaker U1.
#   4. Find the device path on the U1:
#        ls /dev/ttyUSB*
#   5. Set serial: below to the correct path.
#
# GPIO pin notes:
#   heater_pin and sensor_pin use placeholder GPIO numbers.
#   GPIO_NTC_CHAMBER and GPIO_RELAY in board/panda_breath_pins.h are UNVERIFIED —
#   do hardware continuity testing before first use with a live heater.
#   See research/hardware-schematic.md and klipper-firmware/components/klipper/board/panda_breath_pins.h.

[mcu panda_breath]
serial: /dev/ttyUSB0    # adjust if needed; check with: ls /dev/ttyUSB*

# Chamber heater — PTC element switched by relay (on/off only).
# Klipper's PID loop duty-cycles the relay for temperature regulation,
# matching the same approach used by the OEM firmware.
[heater_generic chamber]
heater_pin: panda_breath:gpio10         # GPIO_RELAY — !! verify before use !!
sensor_type: NTC 100K beta 3950
sensor_pin: panda_breath:gpio1          # GPIO_NTC_CHAMBER — !! verify before use !!
control: pid
pid_kp: 10
pid_ki: 0.1
pid_kd: 100
min_temp: 0
max_temp: 60                            # Panda Breath rated max chamber temp

# Klipper thermal safety — required when using heater_generic
[verify_heater chamber]
max_error: 200
check_gain_time: 300    # chamber heats slowly; allow 5 min to reach target
hysteresis: 5
heating_gain: 1

# Optional: expose chamber temp as a named temperature sensor for dashboards
# (Remove if heater_generic above already appears in your UI)
# [temperature_sensor panda_breath_chamber]
# sensor_type: NTC 100K beta 3950
# sensor_pin: panda_breath:gpio1
# min_temp: 0
# max_temp: 70
