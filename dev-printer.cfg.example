# Protocol-only configuration for an ESP32-C3 development board.
# The dev firmware profile initializes no Panda Breath heater or fan pins.

[mcu panda_breath_dev]
serial: /dev/serial/by-id/usb-Espressif_USB_JTAG_serial_debug_unit_*

[printer]
kinematics: none
max_velocity: 1
max_accel: 1

# Most dual-USB-C ESP32-C3 DevKitM-style boards connect their onboard WS2812
# to GPIO8. Confirm the board's silkscreen/schematic if this does not light.
[neopixel c3_status]
pin: panda_breath_dev:gpio8
chain_count: 1
color_order: GRB
initial_RED: 0.05
initial_GREEN: 0.05
initial_BLUE: 0.05
